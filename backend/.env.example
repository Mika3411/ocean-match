NODE_ENV=development
PORT=8080
API_PUBLIC_BASE_URL=http://localhost:8080
DATABASE_URL=postgres://ocean_match:ocean_match@localhost:5432/ocean_match
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

JWT_ACCESS_SECRET=replace-with-a-long-random-access-secret
JWT_REFRESH_SECRET=replace-with-a-long-random-refresh-secret
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=30
BCRYPT_ROUNDS=12

# mock returns a short-lived placeholder upload URL for local integration.
# s3 uses S3-compatible providers such as AWS S3, Cloudflare R2 or MinIO.
PHOTO_STORAGE_DRIVER=mock
PHOTO_BUCKET=ocean-match-photos
PHOTO_PUBLIC_BASE_URL=https://cdn.example.com/ocean-match-photos
S3_REGION=auto
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
